{
  "collectionName": "components_hero_hero_2s",
  "info": {
    "displayName": "Hero 2"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "component",
      "component": "basic.title",
      "repeatable": false
    },
    "textColor": {
      "type": "enumeration",
      "enum": [
        "black",
        "white"
      ],
      "default": "black"
    },
    "buttons": {
      "type": "component",
      "component": "basic.button",
      "repeatable": true
    },
    "showTrialForm": {
      "type": "boolean",
      "default": false
    },
    "trialInputPlaceholder": {
      "type": "string",
      "default": "Work email address"
    },
    "trialButtonLabel": {
      "type": "string",
      "default": "Start Free Trial"
    },
    "trialButtonUrl": {
      "type": "string"
    },
    "lists": {
      "type": "component",
      "component": "basic.lists",
      "repeatable": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "integrationBadge": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "integrationBadgeAlt": {
      "type": "string"
    },
    "backgroundColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "default": "#FFFEF8"
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "certifications": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::certification.certification"
    }
  },
  "config": {}
}
